generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ContestStatus {
  UPCOMING
  DRAFTING
  ACTIVE
  COMPLETED
}

model Manager {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  icon         String?  // emoji or short symbol, e.g. "🐋"
  createdAt    DateTime @default(now())

  picks      ContestPick[]
  standings  Standing[]
  draftSlots DraftSlot[]
}

model Contest {
  id                   String        @id @default(cuid())
  name                 String
  contestNumber        Int
  season               Int
  metricName           String
  metricDescription    String?
  commissionerMessage  String?
  metricExplainer      String?
  savantCsvUrl         String
  metricConfig         Json
  startDate            DateTime
  endDate              DateTime
  draftOpenAt          DateTime
  draftCloseAt         DateTime
  cascadeWindowMinutes Int           @default(60)
  status               ContestStatus @default(UPCOMING)
  hidden               Boolean       @default(false)
  pdxFirst             Boolean       @default(false)
  lastPolledAt         DateTime?
  sweepstakesPhoto     String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  picks      ContestPick[]
  standings  Standing[]
  draftSlots DraftSlot[]

  @@unique([season, contestNumber])
}

model ContestPick {
  id        String   @id @default(cuid())
  contestId String
  managerId String
  teamCode  String
  pickedAt  DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id])
  manager Manager @relation(fields: [managerId], references: [id])

  @@unique([contestId, managerId])
  @@unique([contestId, teamCode])
}

model Standing {
  id             String   @id @default(cuid())
  contestId      String
  managerId      String
  teamCode       String
  metricValue    Float    @default(0)
  rank           Int?
  previousRank   Int?     // rank before the most recent poll — used for trend arrows
  dailyValues    Json?    // { "2025-04-01": 5, "2025-04-02": 3 } — cumulative per date
  relatedValues  Json?    // { "Whiff %": 18.5, "Whiffs/AB": 0.25 }
  dailyOpponents Json?    // { "2025-04-01": "NYM" } — opponent team code per date
  updatedAt      DateTime @updatedAt

  contest Contest @relation(fields: [contestId], references: [id])
  manager Manager @relation(fields: [managerId], references: [id])

  @@unique([contestId, managerId])
}

model DraftSlot {
  id         String    @id @default(cuid())
  contestId  String
  managerId  String
  pickOrder  Int
  eligibleAt DateTime
  pickedAt   DateTime?

  contest Contest @relation(fields: [contestId], references: [id])
  manager Manager @relation(fields: [managerId], references: [id])

  @@unique([contestId, managerId])
  @@unique([contestId, pickOrder])
}
